# Backend
# Секрет для подписи JWT-токенов. На проде ОБЯЗАТЕЛЬНО замени на длинную случайную строку.
JWT_SECRET=change-me-in-production

# Порт бэкенда (по умолчанию 4010; Railway/Heroku подставляют свой PORT автоматически)
PORT=4010

# Путь к файлу SQLite. На Railway указывай путь внутри постоянного volume, например /data/utir.db
DATABASE_PATH=server/utir.db

# Frontend (Vite)
# Адрес бэкенда. На Vercel указать URL из Railway (БЕЗ слеша на конце).
# В локальной разработке оставь пустым — Vite-прокси отправит /api на localhost:4010.
VITE_API_BASE_URL=
